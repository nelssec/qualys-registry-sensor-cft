# Azure AKS Configuration for Qualys Registry Sensor

# Resource Group
resource_group_name = "qualys-registry-sensor-rg"
location            = "eastus"  # Options: eastus, westus2, centralus, northeurope, westeurope, etc.

# AKS Cluster
cluster_name       = "qualys-registry-cluster"
kubernetes_version = "1.28"

# Node Pool Configuration
node_count = 2

# Scanning Level Configuration
# Options:
#   - basic: Vulnerability scanning only (2 CPU, 4 GB - Standard_F2s_v2)
#   - standard: Vulnerability + SCA scanning (4 CPU, 8 GB - Standard_F4s_v2) [DEFAULT]
#   - full: Vulnerability + SCA + Secrets scanning (4 CPU, 8 GB - Standard_F4s_v2)
scanning_level = "standard"

# Azure Container Registry
create_acr = true
acr_name   = ""  # Leave empty for auto-generated name, or specify a globally unique name

# Qualys Configuration (REQUIRED - keep these secret!)
qualys_activation_id = "YOUR_ACTIVATION_ID"
qualys_customer_id   = "YOUR_CUSTOMER_ID"
qualys_pod_url       = "https://your-qualys-platform.qualys.com"

# Optional: Specify custom Qualys image if not using ACR
# qualys_image = "your-registry.azurecr.io/qualys/qcs-sensor:latest"

# GCP GKE Configuration for Qualys Registry Sensor

# GCP Project
project_id = "your-gcp-project-id"
region     = "us-central1"  # Options: us-central1, us-east1, us-west1, europe-west1, asia-southeast1, etc.

# GKE Cluster
cluster_name       = "qualys-registry-cluster"
kubernetes_version = "1.28"

# Network Configuration
network_name = "qualys-registry-network"
subnet_name  = "qualys-registry-subnet"
subnet_cidr  = "10.0.0.0/20"

# Node Pool Configuration
node_count = 1  # Per zone (will be multiplied by number of zones)

# Scanning Level Configuration
# Options:
#   - basic: Vulnerability scanning only (2 CPU, 4 GB - e2-custom-2-4096)
#   - standard: Vulnerability + SCA scanning (4 CPU, 8 GB - e2-custom-4-8192) [DEFAULT]
#   - full: Vulnerability + SCA + Secrets scanning (4 CPU, 8 GB - e2-custom-4-8192)
scanning_level = "standard"

# Google Container Registry
create_gcr = true

# Qualys Configuration (REQUIRED - keep these secret!)
qualys_activation_id = "YOUR_ACTIVATION_ID"
qualys_customer_id   = "YOUR_CUSTOMER_ID"
qualys_pod_url       = "https://your-qualys-platform.qualys.com"

# Optional: Specify custom Qualys image if not using GCR
# qualys_image = "gcr.io/your-project/qualys/qcs-sensor:latest"
